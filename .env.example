# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin:
#   copy .env.example .env

# ============ LLM bağlantısı (ZORUNLU) ============
# Kurum içi / yerel, OpenAI-uyumlu bir uç (vLLM, Ollama, kurum gateway'i).
# URL ve anahtarı kendi ortamınıza göre doldurun; anahtar istemeyen uçlar için
# LLM_API_KEY=dummy yeterlidir.
LLM_BASE_URL=SECRET_URL
LLM_API_KEY=SECRET_API_KEY
LLM_MODEL=qwen3.6-35
LLM_TEMPERATURE=0.0

# Örnek (yerel vLLM):
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=qwen3.6-35
# LLM_API_KEY=dummy

# HTTPS sertifika doğrulaması: kurum içi uç kurum CA'lı/self-signed sertifika
# kullanıyorsa "certificate verify failed" hatası alırsınız — 0 ile kapatın:
# LLM_VERIFY_SSL=0

# Pipeline ayarları (isteğe bağlı):
# USE_CACHE=0            # 1: aynı kolon ikinci kez LLM'e gitmez
# JUDGE_THRESHOLD=0.75        # kazanan kategorinin olasılığı (güven) eşiği.
#                             # Altındaki (teknik olmayan) kolonlar hakeme gider.
#                             # Kalibrasyon: benchmark koşusunda judge_rate %5'in altındaysa
#                             # 0.80'e çıkar, %30'un üstündeyse 0.70'e düşür.
# JUDGE_MARGIN_THRESHOLD=0.25 # olasılık marjı eşiği: en yüksek iki olasılık arasındaki
#                             # fark bu değerin altındaysa (gerçek belirsizlik) — güven
#                             # yüksek olsa bile hakem tetiklenir.
#                             # Kalibrasyon: 0.30 → daha çok kolon hakeme girer (maliyet↑),
#                             # 0.20 → yalnız çok kararsızlar hedeflenir.
# BATCH_SIZE=25          # tek LLM çağrısındaki maksimum kolon sayısı
# REASONING_EFFORT=low   # low/medium/high veya boş (desteklemeyen modelde yok sayılır)
# SINGLE_REASONING_EFFORT=high # tekil sorgunun (derin analiz) düşünme bütçesi;
#                              # toplu koşu REASONING_EFFORT'ta kalır
# LLM_SEED=7             # sağlayıcı destekliyorsa örneklemeyi de sabitler; desteklemiyorsa yok sayılır
# LLM_TIMEOUT=300        # tek çağrı zaman aşımı (sn); yerel uçta düşürülebilir (örn. 120)
# LLM_CONCURRENCY=8      # süreç genelinde aynı anda açık olabilecek maks. LLM isteği
#                         # (merkezi sınır; modlar+tablolar birlikte paralel koştuğundan önemli)

# Yükleme / örnekleme ayarları (isteğe bağlı):
# MAX_UPLOAD_MB=25             # yüklenebilecek maks. Excel boyutu
# SAMPLE_VALUES_PER_COLUMN=5   # ham veri tablosunda kolon başına toplanan örnek değer
# SAMPLE_SCAN_ROWS=500         # ham veri tablosunda taranan maks. satır

# Güvenlik (isteğe bağlı): dolu ise tüm /api/* istekleri X-API-Token başlığı ister.
# Localhost kullanımı için gereksiz; uygulama ağa açılacaksa doldurun.
# APP_API_TOKEN=
