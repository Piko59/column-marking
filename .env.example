# Bu dosyayı .env olarak kopyalayın ve kendi değerlerinizi girin:
#   copy .env.example .env

# Zorunlu: OpenRouter (veya OpenAI-uyumlu sağlayıcı) API anahtarı
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# İsteğe bağlı (varsayılanlar):
# QWEN_BASE_URL=https://openrouter.ai/api/v1
# QWEN_MODEL=qwen/qwen3.6-27b

# Local modele geçiş örneği (vLLM/Ollama):
# QWEN_BASE_URL=http://localhost:8000/v1
# QWEN_MODEL=qwen3-120b
# OPENROUTER_API_KEY=dummy

# Pipeline ayarları (isteğe bağlı):
# USE_CACHE=0            # 1: aynı kolon ikinci kez LLM'e gitmez
# JUDGE_THRESHOLD=0.60   # bu güvenin altındaki (teknik olmayan) kolonlar hakeme gider
# BATCH_SIZE=25          # tek LLM çağrısındaki maksimum kolon sayısı
# REASONING_EFFORT=low   # low/medium/high veya boş
# LLM_TEMPERATURE=0      # tekrarlanabilirlik için varsayılan 0 (deterministik)
# LLM_SEED=7             # sağlayıcı destekliyorsa örneklemeyi de sabitler; desteklemiyorsa yok sayılır
# LLM_CONCURRENCY=8      # süreç genelinde aynı anda açık olabilecek maks. LLM isteği
#                         # (merkezi sınır; modlar+tablolar birlikte paralel koştuğundan önemli)
